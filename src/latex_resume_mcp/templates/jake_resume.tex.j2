%-------------------------
% Resume - Generated by latex-resume-mcp
%------------------------

\documentclass[letterpaper,11pt]{article}

\usepackage{latexsym}
\usepackage[empty]{fullpage}
\usepackage{titlesec}
\usepackage{marvosym}
\usepackage[usenames,dvipsnames]{color}
\usepackage{verbatim}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{fancyhdr}
\usepackage[english]{babel}
\usepackage{tabularx}
\input{glyphtounicode}

\pagestyle{fancy}
\fancyhf{}
\fancyfoot{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

\addtolength{\oddsidemargin}{-0.5in}
\addtolength{\evensidemargin}{-0.5in}
\addtolength{\textwidth}{1in}
\addtolength{\topmargin}{-.5in}
\addtolength{\textheight}{1.0in}

\urlstyle{same}

\raggedbottom
\raggedright
\setlength{\tabcolsep}{0in}

\titleformat{\section}{
  \vspace{-4pt}\scshape\raggedright\large
}{}{0em}{}[\color{black}\titlerule \vspace{-5pt}]

\pdfgentounicode=1

\newcommand{\resumeItem}[1]{
  \item\small{#1 \vspace{-2pt}}
}

\newcommand{\resumeSubheading}[4]{
  \vspace{-2pt}\item
    \begin{tabular*}{0.97\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & #2 \\
      \textit{\small#3} & \textit{\small #4} \\
    \end{tabular*}\vspace{-7pt}
}

\newcommand{\resumeProjectHeading}[2]{
    \item
    \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
      \small#1 & #2 \\
    \end{tabular*}\vspace{-7pt}
}

\newcommand{\resumeSubItem}[1]{\resumeItem{#1}\vspace{-4pt}}

\renewcommand\labelitemii{$\vcenter{\hbox{\tiny$\bullet$}}$}

\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=0.15in, label={}]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}
\newcommand{\resumeItemListStart}{\begin{itemize}}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{-5pt}}

\begin{document}

%----------HEADING----------
\begin{center}
    \textbf{\Huge \scshape << contact.name >>} \\ \vspace{1pt}
    <% if contact.phone %>\small << contact.phone >><% endif %>
    <% if contact.email %> $|$ \href{mailto:<< contact.email >>}{\underline{<< contact.email >>}}<% endif %>
    <% if contact.linkedin %> $|$ \href{https://<< contact.linkedin >>}{\underline{<< contact.linkedin >>}}<% endif %>
    <% if contact.github %> $|$ \href{https://<< contact.github >>}{\underline{<< contact.github >>}}<% endif %>
    <% if contact.website %> $|$ \href{<< contact.website >>}{\underline{<< contact.website >>}}<% endif %>
\end{center}

<% for section in section_order %>
<% if section == "education" and education %>
%-----------EDUCATION-----------
\section{Education}
  \resumeSubHeadingListStart
    <% for edu in education %>
    \resumeSubheading
      {<< edu.institution|latex >>}{<< edu.location|latex >>}
      {<< edu.degree|latex >>}{<< edu.date|latex >>}
      <% if edu.bullets %>
      \resumeItemListStart
        <% for bullet in edu.bullets %>
        \resumeItem{<< bullet|latex >>}
        <% endfor %>
      \resumeItemListEnd
      <% endif %>
    <% endfor %>
  \resumeSubHeadingListEnd

<% elif section == "publications" and publications %>
%-----------PUBLICATIONS-----------
\section{Publications}
    \resumeSubHeadingListStart
      <% for pub in publications %>
      \resumeProjectHeading
          {\textbf{<< pub.title|latex >>}<% if pub.link %> $|$ \href{<< pub.link >>}{\underline{<< pub.link_text|latex >>}}<% endif %>}{<< pub.date|latex >>}
          <% if pub.bullets %>
          \resumeItemListStart
            <% for bullet in pub.bullets %>
            \resumeItem{<< bullet|latex >>}
            <% endfor %>
          \resumeItemListEnd
          <% endif %>
      <% endfor %>
    \resumeSubHeadingListEnd

<% elif section == "experience" and experience %>
%-----------EXPERIENCE-----------
\section{Experience}
  \resumeSubHeadingListStart

    <% for exp in experience %>
    \resumeSubheading
      {<< exp.company|latex >>}{<< exp.location|latex >>}
      {<< exp.title|latex >>}{<< exp.date|latex >>}
      <% if exp.bullets %>
      \resumeItemListStart
        <% for bullet in exp.bullets %>
        \resumeItem{<< bullet|latex >>}
        <% endfor %>
      \resumeItemListEnd
      <% endif %>

    <% endfor %>
  \resumeSubHeadingListEnd

<% elif section == "projects" and projects %>
%-----------PROJECTS-----------
\section{Projects}
    \resumeSubHeadingListStart
      <% for proj in projects %>
      \resumeProjectHeading
          {\textbf{<< proj.name|latex >>}<% if proj.technologies %> $|$ \emph{<< proj.technologies|latex >>}<% endif %>}{<< proj.date|latex >>}
          <% if proj.bullets %>
          \resumeItemListStart
            <% for bullet in proj.bullets %>
            \resumeItem{<< bullet|latex >>}
            <% endfor %>
          \resumeItemListEnd
          <% endif %>
      <% endfor %>
    \resumeSubHeadingListEnd

<% elif section == "skills" and skills %>
%-----------PROGRAMMING SKILLS-----------
\section{Technical Skills}
 \begin{itemize}[leftmargin=0.15in, label={}]
    \small{\item{
     <% for cat in skills %>
     \textbf{<< cat.category|latex >>}{: << cat.skills | join(", ") | latex >>}<% if not loop.last %> \\<% endif %>
     <% endfor %>
    }}
 \end{itemize}

<% endif %>
<% endfor %>
\end{document}
