%-------------------------
% Minimal Resume - Generated by resume-forge-mcp
% Simple, no-frills layout focusing on content
%------------------------

\documentclass[11pt]{article}
\usepackage[utf8]{inputenc}
\usepackage[margin=0.75in]{geometry}
\usepackage{hyperref}
\usepackage{enumitem}

\pagestyle{empty}
\setlength{\parindent}{0pt}

\begin{document}

%----------HEADING----------
\textbf{\Large << contact.name >>}\\[4pt]
<% if contact.email %><< contact.email >><% endif %>
<% if contact.phone %> $|$ << contact.phone >><% endif %>
<% if contact.linkedin %> $|$ \href{<< contact.linkedin >>}{LinkedIn}<% endif %>
<% if contact.github %> $|$ \href{<< contact.github >>}{GitHub}<% endif %>
<% if contact.website %> $|$ \href{<< contact.website >>}{Website}<% endif %>

<% for section in section_order %>
<% if section == "education" and education %>
\vspace{8pt}
\textbf{Education}\hrulefill\\[6pt]
<% for edu in education %>
\textbf{<< edu.degree|latex >>}, << edu.institution|latex >> \hfill << edu.date|latex >>
<% if edu.bullets %>
\begin{itemize}[leftmargin=0.15in, topsep=0pt, parsep=0pt]
<% for bullet in edu.bullets %>
\item \small << bullet|latex >>
<% endfor %>
\end{itemize}
<% endif %>
<% endfor %>

<% elif section == "publications" and publications %>
\vspace{8pt}
\textbf{Publications}\hrulefill\\[6pt]
<% for pub in publications %>
\textbf{<< pub.title|latex >>} \hfill << pub.date|latex >>
<% if pub.link %> --- \href{<< pub.link >>}{<< pub.link_text|latex >>}<% endif %>
<% if pub.bullets %>
\begin{itemize}[leftmargin=0.15in, topsep=0pt, parsep=0pt]
<% for bullet in pub.bullets %>
\item \small << bullet|latex >>
<% endfor %>
\end{itemize}
<% endif %>
<% endfor %>

<% elif section == "experience" and experience %>
\vspace{8pt}
\textbf{Experience}\hrulefill\\[6pt]
<% for exp in experience %>
\textbf{<< exp.title|latex >>}, << exp.company|latex >> \hfill << exp.date|latex >>
<% if exp.bullets %>
\begin{itemize}[leftmargin=0.15in, topsep=0pt, parsep=0pt]
<% for bullet in exp.bullets %>
\item \small << bullet|latex >>
<% endfor %>
\end{itemize}
<% endif %>
<% endfor %>

<% elif section == "projects" and projects %>
\vspace{8pt}
\textbf{Projects}\hrulefill\\[6pt]
<% for proj in projects %>
\textbf{<< proj.name|latex >>}<% if proj.technologies %> --- \textit{<< proj.technologies|latex >>}<% endif %> \hfill << proj.date|latex >>
<% if proj.bullets %>
\begin{itemize}[leftmargin=0.15in, topsep=0pt, parsep=0pt]
<% for bullet in proj.bullets %>
\item \small << bullet|latex >>
<% endfor %>
\end{itemize}
<% endif %>
<% endfor %>

<% elif section == "skills" and skills %>
\vspace{8pt}
\textbf{Skills}\hrulefill\\[6pt]
<% for cat in skills %>
\textbf{<< cat.category|latex >>:} << cat.skills | join(", ") | latex >><% if not loop.last %>\\<% endif %>
<% endfor %>

<% endif %>
<% endfor %>
\end{document}
