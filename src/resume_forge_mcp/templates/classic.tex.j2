%-------------------------
% Classic Resume - Generated by resume-forge-mcp
% Traditional format with horizontal rules
%------------------------

\documentclass[11pt,letterpaper]{article}
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{geometry}
\usepackage{hyperref}
\usepackage{enumitem}

\geometry{margin=1in}
\pagestyle{empty}
\setlength{\parindent}{0pt}

\begin{document}

%----------HEADING----------
\begin{center}
    {\Large\textbf{<< contact.name >>}}\\[6pt]
    <% if contact.phone %><< contact.phone >><% endif %>
    <% if contact.email %> $\bullet$ \href{mailto:<< contact.email >>}{<< contact.email >>}<% endif %>
    <% if contact.linkedin %> $\bullet$ \href{<< contact.linkedin >>}{LinkedIn}<% endif %>
    <% if contact.github %> $\bullet$ \href{<< contact.github >>}{GitHub}<% endif %>
    <% if contact.website %> $\bullet$ \href{<< contact.website >>}{Website}<% endif %>
\end{center}

<% for section in section_order %>
<% if section == "education" and education %>
\vspace{8pt}
\noindent\textbf{\large EDUCATION}\\
\rule{\textwidth}{0.4pt}\\[3pt]
<% for edu in education %>
\textbf{<< edu.institution|latex >>} \hfill << edu.location|latex >>\\
<< edu.degree|latex >> \hfill << edu.date|latex >>
<% if edu.bullets %>
\begin{itemize}[leftmargin=0.2in, topsep=2pt, parsep=0pt]
<% for bullet in edu.bullets %>
    \item \small << bullet|latex >>
<% endfor %>
\end{itemize}
<% endif %>
<% if not loop.last %>\vspace{4pt}<% endif %>
<% endfor %>

<% elif section == "publications" and publications %>
\vspace{8pt}
\noindent\textbf{\large PUBLICATIONS}\\
\rule{\textwidth}{0.4pt}\\[3pt]
<% for pub in publications %>
\textbf{<< pub.title|latex >>} \hfill << pub.date|latex >>
<% if pub.link %>\\
\href{<< pub.link >>}{<< pub.link_text|latex >>}
<% endif %>
<% if pub.bullets %>
\begin{itemize}[leftmargin=0.2in, topsep=2pt, parsep=0pt]
<% for bullet in pub.bullets %>
    \item \small << bullet|latex >>
<% endfor %>
\end{itemize}
<% endif %>
<% endfor %>

<% elif section == "experience" and experience %>
\vspace{8pt}
\noindent\textbf{\large EXPERIENCE}\\
\rule{\textwidth}{0.4pt}\\[3pt]
<% for exp in experience %>
\textbf{<< exp.company|latex >>} \hfill << exp.location|latex >>\\
\textit{<< exp.title|latex >>} \hfill << exp.date|latex >>
<% if exp.bullets %>
\begin{itemize}[leftmargin=0.2in, topsep=2pt, parsep=0pt]
<% for bullet in exp.bullets %>
    \item \small << bullet|latex >>
<% endfor %>
\end{itemize}
<% endif %>
<% if not loop.last %>\vspace{4pt}<% endif %>
<% endfor %>

<% elif section == "projects" and projects %>
\vspace{8pt}
\noindent\textbf{\large PROJECTS}\\
\rule{\textwidth}{0.4pt}\\[3pt]
<% for proj in projects %>
\textbf{<< proj.name|latex >>}<% if proj.technologies %> --- \textit{<< proj.technologies|latex >>}<% endif %> \hfill << proj.date|latex >>
<% if proj.bullets %>
\begin{itemize}[leftmargin=0.2in, topsep=2pt, parsep=0pt]
<% for bullet in proj.bullets %>
    \item \small << bullet|latex >>
<% endfor %>
\end{itemize}
<% endif %>
<% endfor %>

<% elif section == "skills" and skills %>
\vspace{8pt}
\noindent\textbf{\large SKILLS}\\
\rule{\textwidth}{0.4pt}\\[3pt]
<% for cat in skills %>
\textbf{<< cat.category|latex >>:} << cat.skills | join(", ") | latex >>\\
<% endfor %>

<% endif %>
<% endfor %>
\end{document}
