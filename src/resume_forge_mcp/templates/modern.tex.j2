%-------------------------
% Modern Resume - Generated by resume-forge-mcp
% Clean, professional design with color accents
%------------------------

\documentclass[11pt,a4paper]{article}
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{geometry}
\usepackage{hyperref}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage{xcolor}

\geometry{left=0.75in, right=0.75in, top=0.5in, bottom=0.5in}
\pagestyle{empty}
\setlength{\parindent}{0pt}

% Colors
\definecolor{primary}{RGB}{0, 79, 144}
\definecolor{secondary}{RGB}{89, 89, 89}

% Section formatting
\titleformat{\section}{\large\bfseries\color{primary}}{}{0em}{}[\titlerule]
\titlespacing{\section}{0pt}{12pt}{6pt}

% Custom commands
\newcommand{\resumeItem}[1]{\item\small{#1}}
\newcommand{\resumeSubheading}[4]{
  \item
    \begin{tabular*}{\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & {\color{secondary}\small #2} \\
      \textit{\small#3} & {\color{secondary}\small\textit{#4}} \\
    \end{tabular*}\vspace{-5pt}
}
\newcommand{\resumeProjectHeading}[2]{
    \item
    \begin{tabular*}{\textwidth}{l@{\extracolsep{\fill}}r}
      \small#1 & {\color{secondary}\small #2} \\
    \end{tabular*}\vspace{-5pt}
}

\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=0.15in, label={}]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}
\newcommand{\resumeItemListStart}{\begin{itemize}}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{-5pt}}

\begin{document}

%----------HEADING----------
\begin{center}
    {\LARGE\bfseries\color{primary} << contact.name >>}\\[4pt]
    \small
    <% if contact.email %>\href{mailto:<< contact.email >>}{<< contact.email >>}<% endif %>
    <% if contact.phone %> $|$ << contact.phone >><% endif %>
    <% if contact.linkedin %> $|$ \href{<< contact.linkedin >>}{LinkedIn}<% endif %>
    <% if contact.github %> $|$ \href{<< contact.github >>}{GitHub}<% endif %>
    <% if contact.website %> $|$ \href{<< contact.website >>}{Website}<% endif %>
\end{center}

<% for section in section_order %>
<% if section == "education" and education %>
\section{Education}
  \resumeSubHeadingListStart
    <% for edu in education %>
    \resumeSubheading
      {<< edu.institution|latex >>}{<< edu.location|latex >>}
      {<< edu.degree|latex >>}{<< edu.date|latex >>}
      <% if edu.bullets %>
      \resumeItemListStart
        <% for bullet in edu.bullets %>
        \resumeItem{<< bullet|latex >>}
        <% endfor %>
      \resumeItemListEnd
      <% endif %>
    <% endfor %>
  \resumeSubHeadingListEnd

<% elif section == "publications" and publications %>
\section{Publications}
    \resumeSubHeadingListStart
      <% for pub in publications %>
      \resumeProjectHeading
          {\textbf{<< pub.title|latex >>}<% if pub.link %> $|$ \href{<< pub.link >>}{<< pub.link_text|latex >>}<% endif %>}{<< pub.date|latex >>}
          <% if pub.bullets %>
          \resumeItemListStart
            <% for bullet in pub.bullets %>
            \resumeItem{<< bullet|latex >>}
            <% endfor %>
          \resumeItemListEnd
          <% endif %>
      <% endfor %>
    \resumeSubHeadingListEnd

<% elif section == "experience" and experience %>
\section{Experience}
  \resumeSubHeadingListStart
    <% for exp in experience %>
    \resumeSubheading
      {<< exp.company|latex >>}{<< exp.location|latex >>}
      {<< exp.title|latex >>}{<< exp.date|latex >>}
      <% if exp.bullets %>
      \resumeItemListStart
        <% for bullet in exp.bullets %>
        \resumeItem{<< bullet|latex >>}
        <% endfor %>
      \resumeItemListEnd
      <% endif %>
    <% endfor %>
  \resumeSubHeadingListEnd

<% elif section == "projects" and projects %>
\section{Projects}
    \resumeSubHeadingListStart
      <% for proj in projects %>
      \resumeProjectHeading
          {\textbf{<< proj.name|latex >>}<% if proj.technologies %> $|$ \emph{<< proj.technologies|latex >>}<% endif %>}{<< proj.date|latex >>}
          <% if proj.bullets %>
          \resumeItemListStart
            <% for bullet in proj.bullets %>
            \resumeItem{<< bullet|latex >>}
            <% endfor %>
          \resumeItemListEnd
          <% endif %>
      <% endfor %>
    \resumeSubHeadingListEnd

<% elif section == "skills" and skills %>
\section{Skills}
 \begin{itemize}[leftmargin=0.15in, label={}]
    \small{\item{
     <% for cat in skills %>
     \textbf{<< cat.category|latex >>}{: << cat.skills | join(", ") | latex >>}<% if not loop.last %> \\<% endif %>
     <% endfor %>
    }}
 \end{itemize}

<% endif %>
<% endfor %>
\end{document}
